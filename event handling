<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>College Event</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 text-gray-800">

  <!-- Hero Section -->
  <section class="bg-purple-600 text-white text-center py-20">
    <h1 class="text-4xl font-bold">TechFest 2026</h1>
    <p class="mt-4 text-lg">Innovation | Coding | Fun</p>
    <button class="mt-6 bg-white text-purple-600 px-6 py-2 rounded hover:bg-gray-200">
      Register Now
    </button>
  </section>

  <!-- About -->
  <section class="p-10 text-center max-w-3xl mx-auto">
    <h2 class="text-2xl font-bold mb-4">About Event</h2>
    <p>
      TechFest is our annual college event with exciting competitions, workshops, and cultural programs.
    </p>
  </section>

  <!-- Schedule -->
  <section class="bg-gray-200 p-10">
    <h2 class="text-2xl font-bold text-center mb-6">Event Schedule</h2>

    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">

      <div class="bg-white p-5 rounded shadow">
        <h3 class="font-bold text-lg">Day 1</h3>
        <p class="mt-2">Hackathon & Coding Contest</p>
      </div>

      <div class="bg-white p-5 rounded shadow">
        <h3 class="font-bold text-lg">Day 2</h3>
        <p class="mt-2">Workshops & Tech Talks</p>
      </div>

      <div class="bg-white p-5 rounded shadow">
        <h3 class="font-bold text-lg">Day 3</h3>
        <p class="mt-2">Cultural Night & Awards</p>
      </div>

    </div>
  </section>

  <!-- Highlights -->
  <section class="p-10 text-center">
    <h2 class="text-2xl font-bold mb-4">Highlights</h2>
    <p>Guest Speakers | Prizes | Networking | Fun Activities</p>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-800 text-white text-center p-4">
    © 2026 TechFest
  </footer>

</body>
</html>
